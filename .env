# Example environment variables for Open Brain
# Copy this to .env and fill in your values

# Database
DB_NAME=openbrain
DB_USER=postgres
DB_PASSWORD=openbrain
DB_PORT=5433

# Ollama (Embeddings)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDER_MODEL=nomic-embed-text

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Dashboard
STREAMLIT_PORT=8501

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TO=your_email@gmail.com

# Backup (optional)
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
